<?xml version="1.0"?>
<odoo>
    <record id="action_igdb_platforms" model="ir.actions.act_window">
        <field name="name">Platforms</field>
        <field name="path">platforms</field>
        <field name="res_model">igdb.platform</field>
        <field name="view_mode">list,form</field>
    </record>
    <record id="igdb_platform_view_form" model="ir.ui.view">
        <field name="name">igdb.platform.form</field>
        <field name="model">igdb.platform</field>
        <field name="arch" type="xml">
            <form>
                <sheet class="o_igdb_form_sheet_bg">
                    <group>
                        <field name="name"/>
                        <field name="igdb_id"/>
                        <field name="url" widget="url"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="igdb_platform_view_list" model="ir.ui.view">
        <field name="name">igdb.platform.list</field>
        <field name="model">igdb.platform</field>
        <field name="arch" type="xml">
            <list>
                <header>
                    <button name="populate_platforms" string="Populate Platforms" type="object" display="always"/>
                </header>
                <field name="name"/>
                <field name="igdb_id"/>
            </list>
        </field>
    </record>
</odoo>