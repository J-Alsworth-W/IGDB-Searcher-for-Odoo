<?xml version="1.0"?>
<odoo>
    <record id="action_igdb_genres" model="ir.actions.act_window">
        <field name="name">Genres</field>
        <field name="path">genres</field>
        <field name="res_model">igdb.genre</field>
        <field name="view_mode">list,form</field>
    </record>
    <record id="igdb_genre_view_form" model="ir.ui.view">
        <field name="name">igdb.genre.form</field>
        <field name="model">igdb.genre</field>
        <field name="arch" type="xml">
            <form>
                <sheet class="o_igdb_form_sheet_bg">
                    <group>
                        <field name="name"/>
                        <field name="slug"/>
                        <field name="igdb_id"/>
                        <field name="url" widget="url"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="igdb_genre_view_list" model="ir.ui.view">
        <field name="name">igdb.genre.list</field>
        <field name="model">igdb.genre</field>
        <field name="arch" type="xml">
            <list>
                <header>
                    <button name="populate_genres" string="Populate Genres" type="object" display="always"/>
                </header>
                <field name="name"/>
                <field name="slug"/>
                <field name="igdb_id"/>
            </list>
        </field>
    </record>
</odoo>