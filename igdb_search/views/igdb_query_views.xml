<?xml version="1.0"?>
<odoo>
    <record id="action_igdb_queries" model="ir.actions.act_window">
        <field name="name">Queries</field>
        <field name="path">queries</field>
        <field name="res_model">igdb.query</field>
        <field name="view_mode">list,form</field>
    </record>
    <record id="igdb_query_view_form" model="ir.ui.view">
        <field name="name">igdb.query.form</field>
        <field name="model">igdb.query</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="do_search" string="Do Search" type="object"/>
                </header>
                <sheet class="o_igdb_form_sheet_bg">
                    <group>
                        <group string="Name and Query">
                            <field name="name"/>
                            <field name="concatenated_query"/>
                            <field name="where_clause_used" invisible="1"/>
                            <field name="game_name"/>
                            <field name="num_game_limit"/>
                        </group>
                        <group string="Release Date">
                            <field name="release_date_start"/>
                            <field name="release_date_end"/>
                        </group>
                        <group string="Inclusive and Exclusive Filters">
                            <field name="included_platform_ids" widget="many2many_tags" options="{'no_create': True}"/>
                            <field name="excluded_platform_ids" widget="many2many_tags" options="{'no_create': True}"/>
                            <field name="included_genre_ids" widget="many2many_tags" options="{'no_create': True}"/>
                            <field name="excluded_genre_ids" widget="many2many_tags" options="{'no_create': True}"/>
                            <field name="included_theme_ids" widget="many2many_tags" options="{'no_create': True}"/>
                            <field name="excluded_theme_ids" widget="many2many_tags" options="{'no_create': True}"/>
                        </group>
                        <group>

                        </group>
                        <field name="result_game_ids" readonly="1" options="{'no_create': True}"/>
                        <field name="search_completed"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="igdb_query_view_list" model="ir.ui.view">
        <field name="name">igdb.query.list</field>
        <field name="model">igdb.query</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="concatenated_query"/>
                <field name="where_clause_used" column_invisible="1"/>
                <field name="num_game_limit" column_invisible="1"/>
                <field name="game_name"/>
                <field name="release_date_start"/>
                <field name="release_date_end"/>
                <field name="included_platform_ids" widget="many2many_tags"/>
                <field name="excluded_platform_ids" widget="many2many_tags"/>
                <field name="included_genre_ids" widget="many2many_tags"/>
                <field name="excluded_genre_ids" widget="many2many_tags"/>
                <field name="included_theme_ids" widget="many2many_tags"/>
                <field name="excluded_theme_ids" widget="many2many_tags"/>
            </list>
        </field>
    </record>
</odoo>