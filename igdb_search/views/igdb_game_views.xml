<?xml version="1.0"?>
<odoo>
    <record id="action_igdb_games" model="ir.actions.act_window">
        <field name="name">Games</field>
        <field name="path">games</field>
        <field name="res_model">igdb.game</field>
        <field name="view_mode">list,form</field>
    </record>
    <record id="igdb_game_view_form" model="ir.ui.view">
        <field name="name">igdb.game.form</field>
        <field name="model">igdb.game</field>
        <field name="arch" type="xml">
            <form edit="0">
                <sheet class="o_igdb_form_sheet_bg">
                    <group>
                        <field name="name"/>
                        <field name="igdb_id"/>
                        <field name="game_cover" widget="image" invisible="1"/>
                        <field name="first_release_date"/>
                        <field name="url" widget="url"/>
                        <field name="platform_ids" options="{'no_create': True}" widget="many2many_tags"/>
                        <field name="genre_ids" options="{'no_create': True}" widget="many2many_tags"/>
                        <field name="theme_ids" options="{'no_create': True}" widget="many2many_tags"/>
                        <separator/>
                        <field name="query_ids" options="{'no_create': True}">
                            <list>
                                <field name="name"/>
                                <field name="concatenated_query"/>
                                <field name="game_name"/>
                                <field name="included_platform_ids" widget="many2many_tags"/>
                                <field name="excluded_platform_ids" widget="many2many_tags"/>
                            </list>
                        </field>
                        <notebook>
                            <page name="developers" string="Developers">
                                <field name="developer_ids"/>
                            </page>
                            <page name="publishers" string="Publishers">
                                <field name="publisher_ids"/>
                            </page>
                            <page name="porters" string="Porters">
                                <field name="porter_ids"/>
                            </page>
                        </notebook>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="igdb_game_view_list" model="ir.ui.view">
        <field name="name">igdb.game.list</field>
        <field name="model">igdb.game</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="igdb_id"/>
                <field name="first_release_date"/>
                <field name="platform_ids" widget="many2many_tags"/>
                <field name="genre_ids" widget="many2many_tags"/>
                <field name="theme_ids" widget="many2many_tags"/>
            </list>
        </field>
    </record>
</odoo>